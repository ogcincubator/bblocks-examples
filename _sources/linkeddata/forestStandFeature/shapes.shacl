@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix focal-prop: <https://w3id.org/ogc/hosted/focal/properties/> .
@prefix geojson:  <https://purl.org/geojson/vocab#> .

<https://example.com/focal/feature-lesniTyp>
    a                  sh:NodeShape ;
    sh:targetClass     geojson:Feature ;
    sh:property [
        sh:path        focal-prop:lesniTyp ;
        sh:minCount    1 ;
        sh:nodeKind    sh:IRI ;
        sh:name        "lesniTyp" ;
        sh:message     "Every geojson:Feature must have at least one focal-prop:lesniTyp whose value is an IRI resource." ;
    ] .